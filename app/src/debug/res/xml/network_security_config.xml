<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuración de seguridad de red SOLO para builds de debug.

    Android 9+ bloquea el tráfico HTTP en claro por defecto (cleartext).
    Los emuladores locales de Firebase usan HTTP (sin TLS), así que necesitamos
    una excepción explícita para las IPs del emulador.

    Este archivo solo existe en src/debug/ y nunca llega a la build de release.
    En producción Firebase usa HTTPS: no hace falta ninguna excepción.

    127.0.0.1 → móvil físico con `adb reverse`
    10.0.2.2  → AVD de Android Studio
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
